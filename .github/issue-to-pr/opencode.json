{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "limit": {
            "context": 1000000,
            "output": 65536
          }
        }
      }
    }
  },
  "permission": {
    "external_directory": {
      "GDCWS/gdc-premium/**": "allow"
    },
    "edit": {
      "*": "deny",
      "src/**": "allow",
      "docs/**": "allow",
      "package.json": "allow",
      "GDCWS/game-datacards/src/**": "allow",
      "GDCWS/game-datacards/docs/**": "allow",
      "GDCWS/game-datacards/package.json": "allow",
      "GDCWS/gdc-premium/src/**": "allow",
      "GDCWS/gdc-premium/docs/**": "allow"
    },
    "bash": {
      "*": "allow",
      "curl*": "deny",
      "wget*": "deny",
      "nc *": "deny",
      "ncat*": "deny",
      "telnet*": "deny",
      "ssh *": "deny",
      "scp *": "deny",
      "sudo *": "deny",
      "npm *": "deny",
      "npx *": "deny",
      "rm -rf /*": "deny"
    },
    "webfetch": "deny"
  }
}
